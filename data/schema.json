{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Seedance 2.0 Prompt",
  "description": "Schema for a single Seedance 2.0 video generation prompt",
  "type": "object",
  "required": ["id", "title", "content", "language", "thumbnail"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (e.g. 'cinematic-sunset-001')"
    },
    "title": {
      "type": "string",
      "description": "Prompt title (English)"
    },
    "content": {
      "type": "string",
      "description": "The actual prompt text used for generation (English)"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the prompt effect (max 200 chars, English)"
    },
    "language": {
      "type": "string",
      "enum": ["en", "zh-CN", "ja", "pt-BR", "es"],
      "description": "Original language of the prompt"
    },
    "translations": {
      "type": "object",
      "description": "Translated content by locale. Auto-generated by `pnpm run translate`.",
      "patternProperties": {
        "^(zh-CN|ja|pt-BR|es)$": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" },
            "description": { "type": "string" },
            "tips": { "type": "string" }
          }
        }
      }
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "link": { "type": "string", "format": "uri" }
      },
      "required": ["name"]
    },
    "sourceLink": {
      "type": "string",
      "format": "uri",
      "description": "Link to the original post (X/Twitter, etc.)"
    },
    "sourcePublishedAt": {
      "type": "string",
      "format": "date",
      "description": "Original publish date (YYYY-MM-DD)"
    },
    "thumbnail": {
      "type": "string",
      "format": "uri",
      "description": "Video thumbnail image URL"
    },
    "videoUrl": {
      "type": "string",
      "format": "uri",
      "description": "Video URL (not stored on GitHub, just linked)"
    },
    "referenceImages": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "Reference images used as input"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether this prompt is featured/pinned"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for categorization (e.g. ['cinematic', 'nature', 'slow-motion'])"
    },
    "tips": {
      "type": "string",
      "description": "Usage tips and tricks for this prompt (English)"
    }
  }
}
